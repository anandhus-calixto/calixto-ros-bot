<?xml version="1.0"?>
<robot name="my_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="inertial_macros.xacro" />

    <material name="white">  <color rgba="1 1 1 1"/>     </material>
    <material name="blue">   <color rgba="0.2 0.2 1 1"/> </material>
    <material name="black">  <color rgba="0 0 0 1"/>     </material>

    <!-- BASE LINK sits at ground level Z=0 -->
    <link name="base_link"/>

    <!-- ═══════════════════════════════════════
         CHASSIS
         l 300 b 250 h 110
         chassis_joint Z = 0  (base_link at ground)
         collision Z = wheel_radius + half_height
                     = 0.04 + 0.06 = 0.10
         Bottom of box = 0.10 - 0.06 = 0.04  (axle plane)
         Top of box    = 0.10 + 0.06 = 0.16
    ═══════════════════════════════════════ -->
    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz="0 0 0.087" rpy="0 0 0"/>
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://calixto-ros-bot/description/meshes/ROS2-Chassis-URDF.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.3 0.25 0.11"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="0.5" x="0.3" y="0.25" z="0.11">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <gazebo reference="chassis">
        <material>Gazebo/Blue</material>
    </gazebo>
    
<!-- ═══════════════════════════════════════
FL Wheel 4cm rad 4cm length

    ═══════════════════════════════════════ -->

<joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.09 0.152 0.04" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
</joint>

<link name="front_left_wheel">
    <visual>
        <geometry>
            <mesh filename="package://calixto-ros-bot/description/meshes/ROS2-LEFT-URDF.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="black"/>
    </visual>
    <collision>
        <geometry>
            <cylinder radius="0.04" length="0.04"/>
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.1" length="0.04" radius="0.04">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
</link>

<gazebo reference="front_left_wheel">
    <material>Gazebo/Black</material>
</gazebo>

<!-- ═══════════════════════════════════════
RL Wheel 4cm rad 4cm length

    ═══════════════════════════════════════ -->

<joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.09 0.152 0.04" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
</joint>

<link name="rear_left_wheel">
    <visual>
        <geometry>
            <mesh filename="package://calixto-ros-bot/description/meshes/ROS2-LEFT-URDF.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="black"/>
    </visual>
    <collision>
        <geometry>
            <cylinder radius="0.04" length="0.04"/>
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.1" length="0.04" radius="0.04">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
</link>

<gazebo reference="rear_left_wheel">
    <material>Gazebo/Black</material>
</gazebo>

<!-- ═══════════════════════════════════════
FR Wheel 4cm rad 4cm length

    ═══════════════════════════════════════ -->

<joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.085 -0.155 0.04" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
</joint>

<link name="front_right_wheel">
    <visual>
        <geometry>
            <mesh filename="package://calixto-ros-bot/description/meshes/ROS2-RIGHT-URDF.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="black"/>
    </visual>
    <collision>
        <geometry>
            <cylinder radius="0.04" length="0.04"/>
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.1" length="0.04" radius="0.04">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
</link>

<gazebo reference="front_right_wheel">
    <material>Gazebo/Black</material>
</gazebo>

<!-- ═══════════════════════════════════════
RR Wheel 4cm rad 4cm length

    ═══════════════════════════════════════ -->

<joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.085 -0.155 0.04" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
</joint>

<link name="rear_right_wheel">
    <visual>
        <geometry>
            <mesh filename="package://calixto-ros-bot/description/meshes/ROS2-RIGHT-URDF.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="black"/>
    </visual>
    <collision>
        <geometry>
            <cylinder radius="0.04" length="0.04"/>
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.1" length="0.04" radius="0.04">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
</link>

<gazebo reference="rear_right_wheel">
    <material>Gazebo/Black</material>
</gazebo>

    
</robot>
