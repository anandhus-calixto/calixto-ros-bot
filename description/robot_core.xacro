<?xml version="1.0"?>
<robot name="my_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="inertial_macros.xacro" />

    <material name="white">  <color rgba="1 1 1 1"/>      </material>
    <material name="blue">   <color rgba="0.2 0.2 1 1"/> </material>
    <material name="black">  <color rgba="0 0 0 1"/>      </material>
    <material name="red">    <color rgba="1 0 0 1"/>      </material>
    <material name="green">  <color rgba="0 1 0 1"/>      </material>
    <material name="yellow"> <color rgba="1 1 0 1"/>      </material>
    <material name="orange"> <color rgba="1 0.5 0 1"/>   </material>
    <material name="grey">   <color rgba="0.5 0.5 0.5 1"/></material>
    <material name="light_blue"> <color rgba="0.6 0.8 1.0 1.0"/> </material>
    <material name="light_grey"><color rgba="0.7 0.7 0.7 1.0"/></material>


    <link name="base_link"/>

    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz="0 0 0.087" rpy="0 0 0"/>
    </joint>

<link name="chassis">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://calixto-ros-bot/description/meshes/ROS2-Chasis-top-and-bottom-red.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="red"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="0.3 0.25 0.11"/></geometry>
        </collision>
        <xacro:inertial_box mass="0.5" x="0.3" y="0.25" z="0.11">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <gazebo reference="chassis">
        <material>Gazebo/Red</material>
    </gazebo>

    <joint name="battery_joint" type="fixed">
        <parent link="chassis"/>
        <child link="battery_holder"/>
        <origin xyz="0 0 0"/>
    </joint>
    <link name="battery_holder">
        <visual>
            <geometry>
                <mesh filename="package://calixto-ros-bot/description/meshes/ROS2-Chasis-battery-holder-yellow.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="orange"/>
        </visual>
    </link>
    <gazebo reference="battery_holder">
        <material>Gazebo/Yellow</material>
    </gazebo>

    <joint name="comp_joint" type="fixed">
        <parent link="chassis"/>
        <child link="comp_parts"/>
        <origin xyz="0 0 0"/>
    </joint>
    <link name="comp_parts">
        <visual>
            <geometry>
                <mesh filename="package://calixto-ros-bot/description/meshes/ROS2-Chasis-comp-holder-darkblue.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <visual>
            <geometry>
                <mesh filename="package://calixto-ros-bot/description/meshes/ROS2-Chasis-stem-blue.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="light_blue"/>
        </visual>
    </link>
    <gazebo reference="comp_parts">
        <material>Gazebo/Blue</material>
    </gazebo>

    <joint name="acc_joint" type="fixed">
        <parent link="chassis"/>
        <child link="chassis_acc"/>
        <origin xyz="0 0 0"/>
    </joint>
    <link name="chassis_acc">
        <visual> <geometry>
                <mesh filename="package://calixto-ros-bot/description/meshes/ROS2-Chasis-led-holder-black.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="black"/>
        </visual>
        <visual> <geometry>
                <mesh filename="package://calixto-ros-bot/description/meshes/ROS2-Chasis-motors-grey.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="light_grey"/>
        </visual>
    </link>
    <gazebo reference="chassis_acc">
        <material>Gazebo/Grey</material>
    </gazebo>
    
    <joint name="switch_holder_joint" type="fixed">
        <parent link="chassis"/>
        <child link="switch_holder"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="switch_holder">
        <visual>
            <geometry>
                <mesh filename="package://calixto-ros-bot/description/meshes/ROS2-Chasis-switch-holder.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="white"/>
        </visual>
    </link>

    <gazebo reference="switch_holder">
        <material>Gazebo/White</material>
    </gazebo>
    
    
<joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.09 0.152 0.04" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
</joint>

<link name="front_left_wheel">
    <visual>
        <geometry>
            <mesh filename="package://calixto-ros-bot/description/meshes/ROS2-LEFT-URDF.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="black"/>
    </visual>
    <collision>
        <geometry>
            <cylinder radius="0.04" length="0.04"/>
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.1" length="0.04" radius="0.04">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
</link>

<gazebo reference="front_left_wheel">
    <material>Gazebo/Black</material>
</gazebo>

<joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.09 0.152 0.04" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
</joint>

<link name="rear_left_wheel">
    <visual>
        <geometry>
            <mesh filename="package://calixto-ros-bot/description/meshes/ROS2-LEFT-URDF.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="black"/>
    </visual>
    <collision>
        <geometry>
            <cylinder radius="0.04" length="0.04"/>
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.1" length="0.04" radius="0.04">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
</link>

<gazebo reference="rear_left_wheel">
    <material>Gazebo/Black</material>
</gazebo>

<joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.085 -0.155 0.04" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
</joint>

<link name="front_right_wheel">
    <visual>
        <geometry>
            <mesh filename="package://calixto-ros-bot/description/meshes/ROS2-RIGHT-URDF.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="black"/>
    </visual>
    <collision>
        <geometry>
            <cylinder radius="0.04" length="0.04"/>
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.1" length="0.04" radius="0.04">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
</link>

<gazebo reference="front_right_wheel">
    <material>Gazebo/Black</material>
</gazebo>

<joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.085 -0.155 0.04" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
</joint>

<link name="rear_right_wheel">
    <visual>
        <geometry>
            <mesh filename="package://calixto-ros-bot/description/meshes/ROS2-RIGHT-URDF.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="black"/>
    </visual>
    <collision>
        <geometry>
            <cylinder radius="0.04" length="0.04"/>
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="0.1" length="0.04" radius="0.04">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
</link>

<gazebo reference="rear_right_wheel">
    <material>Gazebo/Black</material>
</gazebo>

    
</robot>
